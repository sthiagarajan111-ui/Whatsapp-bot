# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/whatsapp-bot

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=+14155238886
WHATSAPP_PROVIDER=twilio

# Notifications
OWNER_WHATSAPP=971501234567

# Server
PORT=3000

# Flow config
ACTIVE_FLOW=realEstate
CLIENT_NAME=My Real Estate Agency

# Business hours (24hr format, UAE timezone)
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=18
TIMEZONE=Asia/Dubai
BUSINESS_DAYS=1,2,3,4,5,6

# Follow-up timing
FOLLOWUP_DELAY_HOURS=2

# OpenAI API (for voice note transcription via Whisper)
# Get your key at: platform.openai.com/api-keys
# Cost: ~USD 0.006 per minute of audio (30-second voice note ≈ USD 0.003)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Voice feature toggle (set to false to disable without removing code)
VOICE_ENABLED=true

# Daily email reports (Feature 2)
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_gmail_app_password
NOTIFICATION_EMAIL=owner@email.com
REPORT_ENABLED=true
