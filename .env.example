# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/whatsapp-bot

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=+14155238886
WHATSAPP_PROVIDER=twilio

# Notifications
OWNER_WHATSAPP=971501234567

# Server
PORT=3000

# Flow config
ACTIVE_FLOW=realEstate
CLIENT_NAME=My Real Estate Agency

# Business hours (24hr format, UAE timezone)
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=18
TIMEZONE=Asia/Dubai
BUSINESS_DAYS=1,2,3,4,5,6

# Follow-up timing
FOLLOWUP_DELAY_HOURS=2

# OpenAI API (for voice note transcription via Whisper)
# Get your key at: platform.openai.com/api-keys
# Cost: ~USD 0.006 per minute of audio (30-second voice note ≈ USD 0.003)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Voice feature toggle (set to false to disable without removing code)
VOICE_ENABLED=true

# HOT lead instant alerts
HOT_LEAD_ALERTS_ENABLED=true
AGENT_WHATSAPP_NUMBERS=971501234567,971509876543
DASHBOARD_URL=https://your-app.onrender.com/dashboard

# Daily email reports (Feature 2)
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_gmail_app_password
NOTIFICATION_EMAIL=owner@email.com
REPORT_ENABLED=true

# Facebook / Instagram Lead Ads webhook
FB_VERIFY_TOKEN=your_custom_verify_token_string
FB_APP_SECRET=your_facebook_app_secret

# Lead Re-engagement Automation (Feature 1)
REENGAGEMENT_ENABLED=true

# Property Match Push Notifications (Feature 3)
PROPERTY_MATCH_ALERTS=true

# Web Form Webhook — your deployed URL (Feature 7)
RENDER_URL=https://whatsapp-bot-41x7.onrender.com
